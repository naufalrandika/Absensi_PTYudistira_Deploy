# Neon / Vercel Postgres (disarankan)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

SECRET_KEY=ubah-ini-di-production
DEMO_MODE=false

# Opsional: fallback SQL Server lokal (hanya jika DATABASE_URL kosong)
